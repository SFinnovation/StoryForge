# =============================================================================
# StoryForge 前端环境变量（Vite）
# =============================================================================
# 使用方式：
#   cp .env.example .env        （在 frontend/ 目录下执行）
#   或 Windows: copy .env.example .env
#
# 仅 VITE_ 前缀的变量会暴露给浏览器，请勿在此存放后端密钥
# =============================================================================

# 应用标题（浏览器标签页）
VITE_APP_TITLE=StoryForge 灵境档案

# 后端 API 地址（与根目录 .env 中 BACKEND_PORT 保持一致）
VITE_API_BASE_URL=http://localhost:8000/api/v1

# 开发服务器端口（可选，默认 5173）
# VITE_DEV_PORT=5173

# 开发时代理目标（vite.config 若使用 proxy，与此一致）
VITE_BACKEND_ORIGIN=http://localhost:8000

# 是否开启 Mock 数据（无后端时可设为 true，MVP 开发完成后设为 false）
VITE_USE_MOCK=false

# 请求超时（毫秒），AI 行动接口可能较慢
VITE_HTTP_TIMEOUT=90000

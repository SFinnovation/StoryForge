# =============================================================================
# StoryForge 环境变量模板
# =============================================================================

APP_NAME=StoryForge
APP_ENV=development
APP_PORT=8000

# -----------------------------------------------------------------------------
# 数据库
# -----------------------------------------------------------------------------
# 默认与 backend/app/db/database.py 保持一致，从仓库根目录启动时生成 ./storyforge.db
DATABASE_URL=sqlite:///./storyforge.db

# 部署可选 MySQL（需额外安装 pymysql / mysqlclient）
# DATABASE_URL=mysql+pymysql://storyforge:your_password@127.0.0.1:3306/storyforge?charset=utf8mb4

# -----------------------------------------------------------------------------
# 大模型 API
# -----------------------------------------------------------------------------
# LLM_API_KEY 为空时，AI 模块会使用 mock/fallback 响应，便于本地联调。
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=60
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# AI 模块
# -----------------------------------------------------------------------------
AI_MAX_REVISIONS=2
AI_CRITIC_PASS_SCORE=80
AI_CRITIC_MODEL=
AI_CONTEXT_MESSAGE_LIMIT=20
AI_ENABLE_CRITIC=true
AI_FALLBACK_ON_CRITIC_FAIL=true

# -----------------------------------------------------------------------------
# 前端联调
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# 认证与种子数据（当前 JWT 尚未接入，保留为目标态配置）
# -----------------------------------------------------------------------------
SECRET_KEY=change-me-use-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
DEMO_USER_USERNAME=demo
DEMO_USER_PASSWORD=demo123

# -----------------------------------------------------------------------------
# 规则、日志与上传
# -----------------------------------------------------------------------------
RULES_DIR=./rules/dnd5e
LOG_LEVEL=INFO
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5

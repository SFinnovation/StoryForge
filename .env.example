# =============================================================================
# StoryForge 灵境档案 — 环境变量模板（后端）
# =============================================================================
# 使用方式：
#   1. 复制本文件为 .env：  cp .env.example .env   （Windows 见 docs/getting-started.md）
#   2. 填写带「必填」标记的项，尤其是 LLM_API_KEY 与 SECRET_KEY
#   3. 前端另有独立模板：frontend/.env.example → frontend/.env
#
# 注意：.env 已被 .gitignore 忽略，切勿提交真实密钥到 Git
# =============================================================================

# -----------------------------------------------------------------------------
# 应用基础
# -----------------------------------------------------------------------------
APP_NAME=StoryForge
APP_ENV=development
# development | production | test

DEBUG=true
# 生产环境请设为 false

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# 数据库
# -----------------------------------------------------------------------------
# MVP 推荐 SQLite（零配置，文件保存在 backend/data/）
DATABASE_URL=sqlite:///./data/storyforge.db

# 部署可选 MySQL（需安装 pymysql / mysqlclient）
# DATABASE_URL=mysql+pymysql://storyforge:your_password@127.0.0.1:3306/storyforge?charset=utf8mb4

# 是否在启动时自动建表并写入种子数据（世界观、演示账号等）
DB_AUTO_CREATE=true
SEED_DEMO_DATA=true

# -----------------------------------------------------------------------------
# 安全 / JWT（必填：生产环境务必更换）
# -----------------------------------------------------------------------------
# 生成随机密钥（任选一种）：
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#   openssl rand -hex 32
SECRET_KEY=change-me-use-a-long-random-string-in-production

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
# 登录 Token 有效期（分钟），1440 = 24 小时

# -----------------------------------------------------------------------------
# CORS / 前端联调
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 多个来源用英文逗号分隔；生产环境改为实际域名

# -----------------------------------------------------------------------------
# 大模型 API（必填：至少配置一种提供商）
# -----------------------------------------------------------------------------
# 提供商标识，便于切换预设（openai | deepseek | dashscope | custom）
LLM_PROVIDER=deepseek

# --- 通用 OpenAI 兼容接口（DeepSeek / 通义 / OpenAI 等均可用此格式）---
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=
# 【必填】向团队负责人索取，或自行申请后填入

LLM_MODEL=deepseek-chat
LLM_TIMEOUT=60
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# AI 失败重试次数（超时 / JSON 解析失败）
LLM_MAX_RETRIES=2

# --- 预设参考（取消注释并填写 LLM_API_KEY 即可切换）---

# OpenAI
# LLM_PROVIDER=openai
# LLM_API_BASE=https://api.openai.com/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=gpt-4o-mini

# DeepSeek（推荐，性价比高）
# LLM_PROVIDER=deepseek
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=deepseek-chat

# 阿里通义千问（DashScope OpenAI 兼容模式）
# LLM_PROVIDER=dashscope
# LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=qwen-plus

# 智谱 GLM（OpenAI 兼容）
# LLM_PROVIDER=zhipu
# LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
# LLM_API_KEY=xxx
# LLM_MODEL=glm-4-flash

# Moonshot / Kimi
# LLM_PROVIDER=moonshot
# LLM_API_BASE=https://api.moonshot.cn/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=moonshot-v1-8k

# -----------------------------------------------------------------------------
# 演示 / 管理账号（仅开发环境，生产务必修改或关闭 SEED_DEMO_DATA）
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
DEMO_USER_USERNAME=demo
DEMO_USER_PASSWORD=demo123

# -----------------------------------------------------------------------------
# D&D 5e 规则数据
# -----------------------------------------------------------------------------
RULES_DIR=./rules/dnd5e
# 相对 backend/ 工作目录；一般无需修改

# -----------------------------------------------------------------------------
# 日志
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
# DEBUG | INFO | WARNING | ERROR

# 可选：写入文件（留空则仅输出到控制台）
# LOG_FILE=./logs/storyforge.log

# -----------------------------------------------------------------------------
# 可选：Redis（P2 缓存 / 会话，MVP 可不配置）
# -----------------------------------------------------------------------------
# REDIS_URL=redis://127.0.0.1:6379/0

# -----------------------------------------------------------------------------
# 可选：文件上传（头像、世界观封面）
# -----------------------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5

# -----------------------------------------------------------------------------
# AI 模块（双 Agent：主叙事 + 辅审核）
# 详见 docs/ai-module-design.md
# -----------------------------------------------------------------------------
AI_MAX_REVISIONS=2
AI_CRITIC_PASS_SCORE=80
AI_CRITIC_MODEL=
# 留空则使用 LLM_MODEL；可指定更强模型做审核

AI_CONTEXT_MESSAGE_LIMIT=20
AI_ENABLE_CRITIC=true
# 开发调试可设 false 跳过审核（勿用于答辩）

AI_FALLBACK_ON_CRITIC_FAIL=true
# 审核仍失败时使用 fallback_narration.txt 保底叙事

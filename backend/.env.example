# =============================================================================
# StoryForge 后端环境变量
# =============================================================================
# 推荐：直接使用项目根目录的 .env（与本文件内容相同）
#
#   方式 A — 在仓库根目录配置（推荐）
#     cp .env.example .env
#     uvicorn backend.app.main:app --reload --port 8000
#
#   方式 B — 仅在后端目录配置
#     cp .env.example .env
#     （在本目录启动服务）
#
# 完整说明见仓库根目录 .env.example 与 docs/getting-started.md
# =============================================================================

APP_NAME=StoryForge
APP_ENV=development
DEBUG=true
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_PREFIX=/api/v1

DATABASE_URL=sqlite:///./storyforge.db
DB_AUTO_CREATE=true
SEED_DEMO_DATA=true

SECRET_KEY=change-me-use-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

LLM_PROVIDER=deepseek
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=60
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_MAX_RETRIES=2

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
DEMO_USER_USERNAME=demo
DEMO_USER_PASSWORD=demo123

RULES_DIR=../rules/dnd5e
LOG_LEVEL=INFO
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5

AI_MAX_REVISIONS=2
AI_CRITIC_PASS_SCORE=80
AI_CRITIC_MODEL=
AI_CONTEXT_MESSAGE_LIMIT=20
AI_ENABLE_CRITIC=true
AI_FALLBACK_ON_CRITIC_FAIL=true
